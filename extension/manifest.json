{
  "manifest_version": 3,
  "name": "NOCC (dev)",
  "version": "0.0.1",
  "description": "End-to-end encrypted messaging layer for chat platforms — hook required.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "http://localhost:3000/*",
    "<all_urls>"
  ],
  "content_scripts": []
}
