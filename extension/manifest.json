{
  "manifest_version": 3,
  "name": "NOCC (dev)",
  "version": "0.0.1",
  "description": "End-to-end encrypted messaging layer for Discord.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:3000/*", "https://discord.com/*"],
  "content_scripts": [
    {
      "matches": ["https://discord.com/*"],
      "js": ["discord/page-inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://discord.com/*"],
      "js": ["discord/get-user-id.js", "discord/content.js"]
    }
  ]
}
